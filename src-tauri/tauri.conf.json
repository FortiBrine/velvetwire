{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "velvetwire",
  "version": "0.1.1",
  "identifier": "me.fortibrine.velvetwire",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "velvetwire",
        "width": 1100,
        "height": 700,
        "minWidth": 900,
        "minHeight": 580,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Custom Discord Rich Presence manager",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
